{
  "skill_name": "order-collector",
  "description": "마켓 주문 수집·정규화 및 CS 처리 스킬 평가셋",
  "evals": [
    {
      "id": 1,
      "name": "smartstore-sync",
      "prompt": "스마트스토어 주문 동기화가 제대로 동작하는지 확인해줘. _parse_smartstore_order 함수의 매핑이 SambaOrder 스키마에 맞는지, 발주확인 자동 처리가 올바른지 검증.",
      "expected_output": "30필드 매핑 검증, PAYED+NOT_YET 자동 발주확인, 정산금액 계산, 클레임 상태 감지",
      "input_file": "eval-1-smartstore-sync-input.json",
      "expected_output_file": "eval-1-smartstore-sync-expected.json",
      "assertions": [
        { "name": "order_number_매핑", "type": "not_empty", "field": "order_number" },
        { "name": "product_name_매핑", "type": "not_empty", "field": "product_name" },
        { "name": "sale_price_양수", "type": "greater_than", "field": "sale_price", "expected": 0 },
        { "name": "status_유효값", "type": "one_of", "field": "status", "values": ["pending", "shipped", "delivered", "cancelled", "returned", "cancel_requested", "return_requested"] },
        { "name": "shipping_status_한글", "type": "not_empty", "field": "shipping_status" },
        { "name": "revenue_계산됨", "type": "greater_than", "field": "revenue", "expected": 0 },
        { "name": "customer_name_존재", "type": "not_empty", "field": "customer_name" },
        { "name": "source_smartstore", "type": "exact_match", "field": "source", "expected": "smartstore" }
      ]
    },
    {
      "id": 2,
      "name": "claim-handling",
      "prompt": "스마트스토어에서 취소요청이 들어온 주문을 동기화했을 때, 클레임 상태가 올바르게 반영되는지 확인해줘. claimType=CANCEL, claimStatus=CANCEL_REQUEST인 경우.",
      "expected_output": "shipping_status='취소요청', status='cancel_requested', approve_cancel API 호출 가능 확인",
      "input_file": "eval-2-claim-handling-input.json",
      "expected_output_file": "eval-2-claim-handling-expected.json",
      "assertions": [
        { "name": "status_cancel_requested", "type": "exact_match", "field": "status", "expected": "cancel_requested" },
        { "name": "shipping_status_취소요청", "type": "exact_match", "field": "shipping_status", "expected": "취소요청" },
        { "name": "클레임_우선순위", "type": "not_equal", "field": "shipping_status", "unexpected": "배송중" }
      ]
    }
  ]
}
