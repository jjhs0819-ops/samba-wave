# 로컬 이전용 환경변수 — local.env 로 복사해서 채울 것 (git 커밋 금지)
#
# 가장 쉬운 방법:
#   1) 프로덕션 /opt/samba/.env 를 통째로 복사해 local.env 로 저장
#      (JWT/API키/ESM/KAKAO 등 시크릿은 prod 와 동일해야 로그인·기능 정상)
#   2) 아래 [로컬 오버라이드] 항목만 prod 값에서 바꿔치기
#
# ── [로컬 오버라이드] (prod 값 → 아래로 교체) ─────────────────────

# 로컬 Postgres 컨테이너 자격증명 (postgres 서비스가 이걸로 초기화)
LOCAL_DB_USER=samba
LOCAL_DB_PASSWORD=change_me_strong_password
LOCAL_DB_NAME=samba

# 백엔드 → 로컬 Postgres 접속 (host/port 는 compose 가 주입하므로 user/pw/name 만)
# 위 LOCAL_DB_* 와 반드시 동일하게
WRITE_DB_USER=samba
WRITE_DB_PASSWORD=change_me_strong_password
WRITE_DB_NAME=samba
READ_DB_USER=samba
READ_DB_PASSWORD=change_me_strong_password
READ_DB_NAME=samba

# 로컬 PG 는 SSL 미사용
DB_SSL_REQUIRED=false

# 프로덕션 DB 안전가드 비활성 (로컬은 prod DB 아님)
PRODUCTION_DB_HOSTS=

# ── [prod 와 동일하게 유지할 시크릿] (prod .env 에서 그대로 복사) ──
# JWT_SECRET_KEY=...            # 로그인 토큰 — prod 와 동일해야 기존 세션 유효
# API_GATEWAY_KEY=...
# NEXT_PUBLIC_API_GATEWAY_KEY=...
# SAMBA_INVITE_CODE=...
# ESMPLUS_HOSTING_ID=...
# ESMPLUS_SECRET_KEY=...
# KAKAO_API_KEY=...
# KAKAO_REFRESH_TOKEN=...
# KAKAO_SHIP_SECRET=...
# OWNER_DEVICE_IDS=...
# LOTTEON_DAEMON_DEVICE_ID=...
# LOTTEON_FULL_PAGING_ENABLED=...
# AUTOTUNE_QUEUE_CAP=0
# AUTOTUNE_QUEUE_CAP_PER_MARKET=0
# (R2 이미지 프록시 쓰려면 Caddy 단계에서 R2_PUBLIC_HOST 추가)
#
# ── [로컬에선 불필요 — 넣어도 무시됨] ──
# CLOUDSQL_INSTANCE / GCP_PROJECT / AR_REGION / AR_REPO / IMAGE_NAME
# (로컬은 이미지 build 라 AR pull 안 함, Cloud SQL 안 씀)
