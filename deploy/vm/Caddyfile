# Caddy 리버스 프록시 — 자동 HTTPS + Let's Encrypt + Blue/Green 무중단 배포
#
# Blue/Green 동작:
#   - 평소: samba-api(blue) 만 떠있음. Caddy는 active health check로 blue 정상 확인 후 trbutfic 전달.
#   - 배포 시: deploy.sh가 samba-api-staging(green)을 띄움 → green healthy 되면 blue stop
#     → Caddy 가 fail 감지(health_interval 2s)하고 자동으로 green 으로 전환 (lb_policy first 의 next 우선순위)
#     → blue 새 이미지로 재시작 → blue healthy 복귀 시 first 우선이라 자동 blue 복귀 → green stop
#
# 재시작: sudo docker compose restart caddy

api.samba-wave.co.kr {
    reverse_proxy samba-api:8080 samba-api-staging:8080 {
        # 첫번째(blue) 우선 — fail 시에만 두번째(green)로 fallback
        lb_policy first

        # Active 헬스체크 —
        # - timeout 1s → 3s: gunicorn -w 1 단일 event loop이 백그라운드 잡 처리 중
        #   순간 health 응답 1초를 못 맞춰 false-positive fail로 502 윈도우 발생.
        #   3s면 event loop 점유 1~2초 정도는 허용 (실측 기반 — 2026-04-26).
        # - interval 2s → 5s: DNS 폴링 노이즈 감소 + 단일 워커 부담 감소.
        health_uri /api/v1/health
        health_interval 5s
        health_timeout 3s

        # Passive 헬스체크 —
        # - max_fails 1 → 3: 단일 timeout으로 즉시 차단되던 도미노 차단 (staging fallback이
        #   영구 DNS 실패 상태라 단발 fail이 502로 직결됨).
        # - fail_duration 5s → 10s: 진짜 장애일 때만 길게 차단.
        fail_duration 10s
        max_fails 3
        unhealthy_status 5xx

        # 타임아웃 — 마켓 전송 Job 등 긴 요청 대응
        transport http {
            dial_timeout 10s
            response_header_timeout 120s
            read_timeout 300s
        }
    }

    log {
        output file /var/log/caddy/access.log {
            roll_size 10mb
            roll_keep 3
        }
        format json
    }

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
    }
}

# 헬스체크 전용 엔드포인트
:80 {
    respond /health "OK" 200
    redir https://{host}{uri} permanent
}
