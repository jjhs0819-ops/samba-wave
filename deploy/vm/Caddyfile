# Caddy 리버스 프록시 — 자동 HTTPS + Let's Encrypt
#
# 사용법:
# 1. 도메인을 VM 외부 IP로 A 레코드 설정
# 2. {DOMAIN} 자리에 실제 도메인 입력 (예: api.samba-wave.com)
# 3. 재시작: sudo docker compose restart caddy
#
# HTTPS 인증서는 자동 발급/갱신. 사람이 할 일 없음.

api.samba-wave.com {
    reverse_proxy samba-api:8080 {
        # 업스트림 헬스체크 — API가 ready 상태일 때만 트래픽 전달
        health_uri /api/v1/health
        health_interval 30s
        health_timeout 5s

        # 타임아웃 — 마켓 전송 Job 등 긴 요청 대응
        transport http {
            dial_timeout 10s
            response_header_timeout 120s
            read_timeout 300s
        }
    }

    # 요청/응답 로그 (용량 제한)
    log {
        output file /var/log/caddy/access.log {
            roll_size 10mb
            roll_keep 3
        }
        format json
    }

    # 보안 헤더
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
    }
}

# 헬스체크 전용 엔드포인트 (로드밸런서/모니터링용)
:80 {
    respond /health "OK" 200
    redir https://{host}{uri} permanent
}
