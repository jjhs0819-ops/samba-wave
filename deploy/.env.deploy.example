# deploy/deploy.sh 가 source 하는 운영 식별자 + 시크릿 템플릿.
#
# 사용법:
#   1) 이 파일을 ~/samba-vm-secrets/deploy.env 또는 deploy/.env.deploy 로 복사
#   2) 실제 값으로 치환
#   3) git 커밋 금지 (.gitignore 에 포함)
#
# deploy.sh 가 우선순위 ENV_FILE → gcloud config 폴백으로 읽음.

# ── GCP / Artifact Registry ───────────────────────────────
# PROJECT_ID — 본인 GCP project ID. 미설정 시 `gcloud config get-value project` 폴백.
PROJECT_ID=your-gcp-project-id
AR_REGION=asia-northeast3
AR_REPO=cloud-run-source-deploy
IMAGE_NAME=samba-wave-api

# ── VM SSH ─────────────────────────────────────────────────
# 본인 운영 VM 도메인 또는 외부 IP. 본인 SSH user 명.
VM_HOST=api.your-domain.com
VM_USER=your-ssh-user
# SSH 키 경로 (기본값 $HOME/samba-vm-secrets/ssh/deploy_key)
SSH_KEY=

# ── 카카오 알림 (선택) ────────────────────────────────────
KAKAO_API_KEY=
KAKAO_REFRESH_TOKEN=
