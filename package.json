{
  "name": "samba-wave",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n \"backend,frontend\" -c \"yellow,cyan\" \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && .venv/Scripts/python -m uvicorn backend.main:app --reload --port 28080",
    "dev:frontend": "cd frontend && pnpm dev"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}
