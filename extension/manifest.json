{
  "manifest_version": 3,
  "name": "SAMBA-WAVE",
  "version": "1.4.0",
  "description": "무재고 위탁판매 솔루션 - 무신사 수집 + 롯데홈쇼핑 OpenAPI 연동",
  "permissions": [
    "cookies",
    "storage",
    "tabs",
    "webRequest"
  ],
  "host_permissions": [
    "https://*.musinsa.com/*",
    "http://localhost:3001/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
