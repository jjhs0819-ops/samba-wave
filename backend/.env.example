# ============================================
# 삼바웨이브 백엔드 환경변수 (.env)
# ============================================
# 이 파일을 .env로 복사하면 바로 사용 가능합니다.
# cp .env.example .env
#
# 🚨 .env 파일은 절대 git에 올리지 마세요!
# ============================================

# 환경 (development / staging / production)
environment=development

# ============================================
# 데이터베이스 — Docker Compose 로컬 DB 기준
# (docker-compose up 으로 DB 띄우면 아래 값 그대로 사용)
# ============================================
WRITE_DB_USER=test_user
WRITE_DB_PASSWORD=test_password
WRITE_DB_HOST=localhost
WRITE_DB_PORT=5433
WRITE_DB_NAME=test_little_boy

READ_DB_USER=test_user
READ_DB_PASSWORD=test_password
READ_DB_HOST=localhost
READ_DB_PORT=5433
READ_DB_NAME=test_little_boy

# 로컬 개발에서는 SSL 끄기
DB_SSL_REQUIRED=false

# ============================================
# JWT 시크릿 키 (로컬 개발용 — 아무 문자열이나 OK)
# ============================================
JWT_SECRET_KEY=local-dev-secret-key-12345

# ============================================
# [선택] 아래는 없어도 서버 실행됨 — 필요할 때 추가
# ============================================
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# ANTHROPIC_API_KEY=
# REDIS_URL=

# ============================================
# [선택] 로컬 LLM (Ollama / Hermes) — 맥미니 두뇌
# 기본값으로 동작하므로 보통 비워둬도 됨.
# - 같은 머신에서 Ollama 구동: 아래 그대로(127.0.0.1)
# - 클라우드에서 원격 맥미니 호출: Tailscale IP 로 지정
#   (맥미니에서 OLLAMA_HOST=0.0.0.0 으로 Ollama 바인딩 필요)
# ============================================
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# HERMES_MODEL=hermes3:8b
# 텍스트 생성 제공자 토글 (gemma | hermes), 기본 gemma
# AI_TEXT_PROVIDER=gemma

# ============================================
# [선택] Caddy /images/* → R2 reverse proxy 용
# 자기 R2 버킷의 public host (https:// 없이 호스트만)
# 예: pub-0a884386abd84479a98975550fc32055.r2.dev
# 롯데홈쇼핑 등 일부 마켓 API가 r2.dev 도메인 다운로드 실패하는 케이스에서
# 자체 도메인 경유 우회용. samba_settings.cloudflare_r2.public_url 도 같이 변경해야 동작.
# ============================================
# R2_PUBLIC_HOST=pub-XXXXXXXX.r2.dev
