# ============================================
# 삼바웨이브 백엔드 환경변수 (.env)
# ============================================
# 이 파일을 .env로 복사하면 바로 사용 가능합니다.
# cp .env.example .env
#
# 🚨 .env 파일은 절대 git에 올리지 마세요!
# ============================================

# 환경 (development / staging / production)
environment=development

# ============================================
# 데이터베이스 — Docker Compose 로컬 DB 기준
# (docker-compose up 으로 DB 띄우면 아래 값 그대로 사용)
# ============================================
WRITE_DB_USER=test_user
WRITE_DB_PASSWORD=test_password
WRITE_DB_HOST=localhost
WRITE_DB_PORT=5433
WRITE_DB_NAME=test_little_boy

READ_DB_USER=test_user
READ_DB_PASSWORD=test_password
READ_DB_HOST=localhost
READ_DB_PORT=5433
READ_DB_NAME=test_little_boy

# 로컬 개발에서는 SSL 끄기
DB_SSL_REQUIRED=false

# ============================================
# JWT 시크릿 키 (로컬 개발용 — 아무 문자열이나 OK)
# ============================================
JWT_SECRET_KEY=local-dev-secret-key-12345

# ============================================
# [선택] 아래는 없어도 서버 실행됨 — 필요할 때 추가
# ============================================
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# ANTHROPIC_API_KEY=
# REDIS_URL=
