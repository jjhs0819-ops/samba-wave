# 삼바웨이브 로컬 배경제거 워커 설정
# 이 파일을 .env로 복사한 뒤 값을 채워주세요
# cp .env.example .env

# 백엔드 API URL (프로덕션)
SAMBA_API_URL=https://api.samba-wave.com

# 삼바웨이브 로그인 토큰 (브라우저 개발자도구 → Application → Cookies → token 값)
SAMBA_TOKEN=여기에_토큰_붙여넣기

# Cloudflare R2 설정 (삼바웨이브 설정 페이지와 동일한 값)
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=
R2_PUBLIC_URL=https://

# 폴링 간격 (초, 기본 5)
POLL_INTERVAL=5
