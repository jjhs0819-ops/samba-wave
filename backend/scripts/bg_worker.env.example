# Samba Wave Local BG Worker Config
# Copy this file to bg_worker.env and fill in WORKER_TOKEN
#
# WORKER_TOKEN: Settings > Cloudflare R2 > Local Worker Token > Click "Generate Token" and copy

SAMBA_API_URL=https://samba-wave-api-363598397345.asia-northeast3.run.app
WORKER_TOKEN=paste_your_token_here

# Poll interval in seconds (default: 5)
POLL_INTERVAL=5
